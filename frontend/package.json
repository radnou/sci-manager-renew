{
	"name": "svelte-test",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:high-value": "vitest run -c vitest.high-value.config.ts",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:validate": "playwright test --config=e2e/playwright.validation.config.ts",
		"test:e2e:validate:p0": "playwright test --config=e2e/playwright.validation.config.ts --grep @P0",
		"test:e2e:showcase": "playwright test --config=e2e/playwright.showcase.config.ts",
		"test:e2e:showcase:desktop": "playwright test --config=e2e/playwright.showcase.config.ts --project=desktop",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@inlang/paraglide-js": "^2.10.0",
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.2.15",
		"@storybook/addon-docs": "^10.2.15",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/addon-vitest": "^10.2.15",
		"@storybook/sveltekit": "^10.2.15",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/d3-scale": "^4.0.9",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "4.0.18",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.16.2",
		"chrome-launcher": "^1.2.1",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.2.15",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"lighthouse": "^13.0.3",
		"mdsvex": "^0.12.6",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.2.15",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@sentry/sveltekit": "^10.42.0",
		"@stripe/stripe-js": "^8.9.0",
		"@supabase/supabase-js": "^2.98.0",
		"d3-scale": "^4.0.2",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^0.577.0",
		"node-fetch": "^3.3.2",
		"stripe": "^20.4.0"
	}
}

# App
APP_ENV=development
APP_NAME=GererSCI
DEBUG=false

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1","*.gerersci.fr"]

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# Database (local Postgres/Supabase)
DATABASE_HOST=supabase-db
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@supabase-db:5432/postgres

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@gerersci.fr

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_secret_here
STRIPE_STARTER_PRICE_ID=price_starter_placeholder
STRIPE_PRO_PRICE_ID=price_pro_placeholder
STRIPE_LIFETIME_PRICE_ID=price_lifetime_placeholder

# Frontend Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional observability
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature flags
FEATURE_CERFA_GENERATION=true
FEATURE_STRIPE_PAYMENTS=true
FEATURE_PLAN_ENTITLEMENTS_ENFORCEMENT=enforce
FEATURE_NEW_CHECKOUT_CATALOG=true
FEATURE_PDF_RENDER_DIRECT=true
FEATURE_MULTI_SCI_DASHBOARD_V2=true
PUBLIC_FEATURE_MULTI_SCI_DASHBOARD_V2=true

# External service controls
EXTERNAL_RETRY_ATTEMPTS=3
EXTERNAL_RETRY_BASE_DELAY_MS=200
STRIPE_REQUEST_TIMEOUT_SECONDS=10
SUPABASE_REQUEST_TIMEOUT_SECONDS=10
RESEND_REQUEST_TIMEOUT_SECONDS=10
DATABASE_SOCKET_TIMEOUT_SECONDS=2

# App
APP_ENV=development
APP_NAME=SCI-Manager

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:5173"]

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# Database (local Postgres/Supabase)
DATABASE_HOST=supabase-db
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@supabase-db:5432/postgres

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_starter_replace_me
STRIPE_PRICE_PRO=price_pro_replace_me
STRIPE_PRICE_LIFETIME=price_lifetime_replace_me

# Frontend Stripe price mappings
VITE_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
VITE_STRIPE_PRICE_STARTER=${STRIPE_PRICE_STARTER}
VITE_STRIPE_PRICE_PRO=${STRIPE_PRICE_PRO}
VITE_STRIPE_PRICE_LIFETIME=${STRIPE_PRICE_LIFETIME}

# Optional observability
LOG_LEVEL=INFO

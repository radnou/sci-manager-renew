# Environment variables example

# Stripe keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase
# use the URL of your Supabase project; during local development this
# defaults to http://localhost:54321 when the Docker stack is running.
SUPABASE_URL=https://your-project.supabase.co
# an anon key is enough for simple operations; the service role key is required
# for privileged server‑side actions.
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role

# ============================================================
# GererSCI — Production Environment Variables
# ============================================================
# Copy this file: cp .env.production.example .env
# Then fill in ALL values marked with <CHANGE_ME>

# ---- Application ----
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
LOG_FORMAT=json

# ---- URLs ----
FRONTEND_URL=https://app.gerersci.fr
VITE_API_URL=https://api.gerersci.fr
CORS_ORIGINS=["https://app.gerersci.fr","https://gerersci.fr","https://www.gerersci.fr"]
ALLOWED_HOSTS=gerersci.fr,*.gerersci.fr

# ---- Supabase ----
SUPABASE_URL=<CHANGE_ME>
SUPABASE_ANON_KEY=<CHANGE_ME>
SUPABASE_SERVICE_ROLE_KEY=<CHANGE_ME>
SUPABASE_JWT_SECRET=<CHANGE_ME>

# ---- Stripe ----
STRIPE_SECRET_KEY=<CHANGE_ME_sk_live_or_sk_test>
STRIPE_PUBLISHABLE_KEY=<CHANGE_ME_pk_live_or_pk_test>
STRIPE_WEBHOOK_SECRET=<CHANGE_ME_whsec>
STRIPE_STARTER_PRICE_ID=<CHANGE_ME>
STRIPE_PRO_PRICE_ID=<CHANGE_ME>
STRIPE_LIFETIME_PRICE_ID=<CHANGE_ME>
VITE_STRIPE_PUBLISHABLE_KEY=<CHANGE_ME_pk_live_or_pk_test>

# ---- Email (Resend) ----
RESEND_API_KEY=<CHANGE_ME_re_>
RESEND_FROM_EMAIL=noreply@gerersci.fr

# ---- Sentry ----
SENTRY_DSN=
VITE_SENTRY_DSN=

# ---- Feature Flags ----
FEATURE_PLAN_ENTITLEMENTS_ENFORCEMENT=enforce
PUBLIC_FEATURE_MULTI_SCI_DASHBOARD_V2=true

# ---- Matomo Analytics ----
VITE_MATOMO_URL=https://analytics.gerersci.fr
VITE_MATOMO_SITE_ID=1
MATOMO_DB_ROOT_PASSWORD=<CHANGE_ME>
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=<CHANGE_ME>

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME>

# ---- Staging overrides (optional) ----
# STAGING_SUPABASE_URL=
# STAGING_SUPABASE_ANON_KEY=
# STAGING_SUPABASE_SERVICE_ROLE_KEY=
# STAGING_SUPABASE_JWT_SECRET=
